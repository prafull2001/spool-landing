rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth.uid == userId;

      match /excuses/{excuseId} {
        allow read, write: if request.auth.uid == userId;
        allow read: if request.auth.uid != userId &&
          exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
      }

      match /friends/{friendId} {
        allow write: if request.auth != null;
        allow read: if request.auth.uid == userId;
      }
    }

    // Collection group rule for excuse analytics dashboard
    match /{path=**}/excuses/{excuseId} {
      allow read: if request.auth != null;
    }

    match /friend_requests/{requestId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth.uid == resource.data.from_uid
        || request.auth.uid == resource.data.to_uid;
    }

    match /top_apps_optimized/{document} {
      allow read: if true;
    }

    match /accounts_to_delete/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    match /onboarding_sessions/{sessionId} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    match /onboarding_events/{eventId} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    match /onboarding_surveys/{surveyId} {
      allow write: if true;
      allow read: if request.auth != null;
    }
  }
}